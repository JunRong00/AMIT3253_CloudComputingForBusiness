# Copy this file to .env and fill in real values. .env is git-ignored and
# never committed - only this .env.example (with blank placeholders) is
# tracked in the repo. See config.php for how each value is used.

# Database (leave blank to use the local/Docker defaults in config.php)
DB_HOST=
DB_USER=
DB_PASS=
DB_NAME=

# Photo storage (S3) - optional, leave all blank to keep saving photos to
# the local uploads/ folder
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
